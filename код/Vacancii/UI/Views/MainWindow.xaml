<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:UI.ViewModels"
        xmlns:local="clr-namespace:UI"
        mc:Ignorable="d"
        Title="🔍 Система поиска вакансий — Инвертированный индекс (SPIMI)"
        Width="1280"
        Height="820"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <TabControl Margin="8"
                Background="Transparent"
                BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="FontSize"
                        Value="14" />
                <Setter Property="FontWeight"
                        Value="SemiBold" />
                <Setter Property="Padding"
                        Value="16,8" />
            </Style>
        </TabControl.Resources>

        <!-- ==================== TAB 1: ПОИСК ==================== -->
        <TabItem Header="🔍 Поиск">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Строка поиска -->
                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Поисковый запрос"
                                   Style="{StaticResource SectionHeader}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchTextBox}"
                                     Margin="0,0,8,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding SearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="1"
                                    Content="🔍 Найти"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SearchCommand}"
                                    Margin="0,0,4,0" />

                            <Button Grid.Column="2"
                                    Content="✕ Очистить"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ClearCommand}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,0">
                            <CheckBox Content="Простой режим (слова через AND)"
                                      IsChecked="{Binding UseSimpleMode}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,20,0" />
                            <TextBlock Text="Булев синтаксис: AND, OR, NOT, скобки ()"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Инфо строка -->
                <Border Grid.Row="1"
                        Style="{StaticResource Card}"
                        Margin="0,0,0,8"
                        Padding="16,8"
                        Visibility="{Binding SearchInfo, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SearchInfo}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,20,0" />
                        <TextBlock Text="Запрос: "
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding ParsedQuery}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Результаты -->
                <Border Grid.Row="2"
                        Style="{StaticResource Card}">
                    <Grid>
                        <!-- Если индекс не загружен -->
                        <TextBlock Text="⚠ Сначала постройте индекс на вкладке «Индексация»"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsIndexLoaded,
                               Converter={StaticResource BoolToVis},
                               ConverterParameter=Inverse}" />

                        <ListView ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedResult}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="16,12"
                                            Background="#FAFBFC"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Ранк -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Rank, StringFormat='#{0}'}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       VerticalAlignment="Top" />

                                            <!-- Основная инфа -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0">
                                                <TextBlock Text="{Binding Vacancy.Title}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Vacancy.Company}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text=" • "
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding Vacancy.Location}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Text=" • "
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding Vacancy.Employment}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Vacancy.Description}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="40"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0" />
                                                <TextBlock Text="{Binding TagsDisplay}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0" />
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource SuccessBrush}"
                                                           Margin="0,2,0,0">
                                            <Run Text="Совпавшие термы: " />
                                            <Run Text="{Binding MatchedTerms}"
                                                    FontWeight="SemiBold" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Зарплата и скор -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Top"
                                                        HorizontalAlignment="Right"
                                                        MinWidth="150">
                                                <TextBlock Text="{Binding SalaryDisplay}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource SuccessBrush}"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding Score, StringFormat='Score: {0:F2}'}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Статус бар -->
                <Border Grid.Row="3"
                        Margin="0,8,0,0"
                        Padding="8,4"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="6">
                    <TextBlock Text="{Binding StatsText}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </TabItem>

        <!-- ==================== TAB 2: ИНДЕКСАЦИЯ ==================== -->
        <TabItem Header="⚙ Индексация">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Левая панель — настройки -->
                <StackPanel Grid.Column="0"
                            Margin="0,0,8,0">
                    <!-- Настройки генерации -->
                    <Border Style="{StaticResource Card}"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="⚙ Настройки индексации"
                                       Style="{StaticResource SectionHeader}" />

                            <TextBlock Text="Количество документов (вакансий):"
                                       FontSize="13"
                                       Margin="0,0,0,4" />
                            <TextBox Text="{Binding DocumentCount}"
                                     Style="{StaticResource SearchTextBox}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Размер SPIMI-блока (макс. термов):"
                                       FontSize="13"
                                       Margin="0,0,0,4" />
                            <TextBox Text="{Binding BlockSize}"
                                     Style="{StaticResource SearchTextBox}"
                                     Margin="0,0,0,16" />

                            <Button Content="🔨 Построить индекс"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BuildIndexCommand}"
                                    IsEnabled="{Binding IsNotIndexing}"
                                    Margin="0,0,0,8" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 Сохранить"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding SaveIndexCommand}"
                                        Margin="0,0,8,0" />
                                <Button Content="📂 Загрузить"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding LoadIndexCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Прогресс -->
                    <Border Style="{StaticResource Card}"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="📊 Прогресс"
                                       Style="{StaticResource SectionHeader}" />
                            <ProgressBar Value="{Binding IndexProgress}"
                                         Maximum="100"
                                         Height="20"
                                         Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="{Binding IndexProgress, StringFormat='{}{0:F0}%'}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <!-- Статистика -->
                    <Border Style="{StaticResource Card}"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="📈 Статистика индекса"
                                       Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="{Binding StatsText}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       LineHeight="22" />
                        </StackPanel>
                    </Border>

                    <!-- Поиск по словарю -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📖 Поиск терма в индексе"
                                       Style="{StaticResource SectionHeader}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding TermLookup, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SearchTextBox}"
                                         Margin="0,0,8,0">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter"
                                                    Command="{Binding LookupTermCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1"
                                        Content="🔎"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding LookupTermCommand}" />
                            </Grid>
                            <TextBlock Text="{Binding TermInfo}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Правая панель — лог -->
                <Border Grid.Column="1"
                        Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="📋 Лог индексации"
                                   Style="{StaticResource SectionHeader}" />
                        <ListBox ItemsSource="{Binding LogMessages}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,1" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ==================== TAB 3: О ПРОГРАММЕ ==================== -->
        <TabItem Header="ℹ О программе">
            <Border Style="{StaticResource Card}"
                    Margin="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="800">
                        <TextBlock Text="Система поиска вакансий"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Курсовая работа: Поисковые системы. Инвертированный индекс."
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,24" />

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="24"
                                   Foreground="{StaticResource TextBrush}">
                    <Bold>Алгоритм индексации:</Bold> Single-Pass In-Memory Indexing (SPIMI)
                    <LineBreak /><LineBreak />
                    <Bold>Принцип работы SPIMI:</Bold>
                    <LineBreak />
                    1. Документы обрабатываются последовательно (поток пар term–docID)
                    <LineBreak />
                    2. Для каждого терма создаётся постинг-лист прямо в словаре блока
                    <LineBreak />
                    3. Когда блок заполняется (лимит по памяти) — термы сортируются и блок сбрасывается
                    <LineBreak />
                    4. После обработки всех документов — все блоки сливаются (multi-way merge)
                    <LineBreak /><LineBreak />
                    <Bold>Отличие от BSBI:</Bold> SPIMI не использует глобальный маппинг term→termID,
                    а хранит сами строки-термы как ключи словаря, что позволяет динамически
                    добавлять новые термы без предварительного прохода по коллекции.
                    <LineBreak /><LineBreak />
                    <Bold>Обработка булевых запросов:</Bold>
                    <LineBreak />
                    • AND — пересечение отсортированных постинг-листов за O(n+m)
                    <LineBreak />
                    • OR — объединение за O(n+m)
                    <LineBreak />
                    • NOT — дополнение до полного множества документов
                    <LineBreak />
                    • Поддержка скобок для группировки
                    <LineBreak /><LineBreak />
                    <Bold>Примеры запросов:</Bold>
                    <LineBreak />
                    • python AND django
                    <LineBreak />
                    • (java OR c#) AND senior AND NOT стажировка
                    <LineBreak />
                    • москва AND (python OR go) AND NOT junior
                    <LineBreak />
                    • devops AND kubernetes AND docker
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </TabItem>
    </TabControl>
</Window>
